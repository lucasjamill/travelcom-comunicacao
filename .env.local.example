# Supabase (new publishable/secret keys — find at Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Anthropic (script generation)
ANTHROPIC_API_KEY=

# Telnyx
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=
TELNYX_FROM_NUMBER=

# OpenAI (TTS script preview + Realtime API for live translation)
OPENAI_API_KEY=

# Translation Bridge Server (Railway deployment URL)
# e.g. https://travelcom-bridge-production.up.railway.app
BRIDGE_SERVER_URL=
# Shared secret between Next.js API and bridge (optional but recommended)
BRIDGE_API_SECRET=

# App / Webhooks
# For local dev with ngrok: WEBHOOK_BASE_URL=https://xxxx-xxxx.ngrok-free.app
# On Vercel: leave empty — auto-detected from VERCEL_PROJECT_PRODUCTION_URL
WEBHOOK_BASE_URL=
WEBHOOK_SECRET=
